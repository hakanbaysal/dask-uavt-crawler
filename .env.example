# ── DASK API ──────────────────────────────
DASK_BASE_URL=https://adreskodu.dask.gov.tr

# ── PostgreSQL ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dask_uavt
DB_USER=postgres
DB_PASSWORD=changeme

# ── Crawler Settings ─────────────────────
REQUEST_DELAY=1.0
MAX_RETRIES=3
RETRY_DELAY=5.0
REQUEST_TIMEOUT=30

# ── Logging ──────────────────────────────
LOG_LEVEL=INFO

# ── Checkpoint ───────────────────────────
CHECKPOINT_DIR=checkpoints

# ── Crawl Scope (optional filters) ──────
# START_CITY_CODE=34
# END_CITY_CODE=34
